# name: test/sql/sklearn_transforms.test
# description: Unsupervised transforms (buffering fit_transform) end-to-end
# group: [vgi_sklearn]

require-env VGI_SKLEARN_WORKER

require vgi

require httpfs

statement ok
ATTACH 'sklearn' AS sklearn (TYPE vgi, LOCATION '${VGI_SKLEARN_WORKER}');

# A numeric feature view of iris (drop target / target_name).
statement ok
CREATE TEMP VIEW iris_feats AS
  SELECT sample_id, sepal_length_cm, sepal_width_cm, petal_length_cm, petal_width_cm
  FROM sklearn.iris();

# ---- StandardScaler: rows preserved, scaled column has ~0 mean and ~1 std ----

query I
SELECT count(*) FROM sklearn.standard_scaler((SELECT * FROM iris_feats), id => 'sample_id');
----
150

query II
SELECT abs(avg(sepal_length_cm)) < 1e-9, abs(stddev_pop(sepal_length_cm) - 1) < 1e-6
FROM sklearn.standard_scaler((SELECT * FROM iris_feats), id => 'sample_id');
----
true	true

# id is carried through unchanged and is joinable
query I
SELECT count(*) FROM sklearn.standard_scaler((SELECT * FROM iris_feats), id => 'sample_id') s
JOIN sklearn.iris() i USING (sample_id);
----
150

# ---- MinMaxScaler: every value lands in [0, 1] ----

query I
SELECT bool_and(petal_length_cm BETWEEN 0 AND 1)
FROM sklearn.minmax_scaler((SELECT * FROM iris_feats), id => 'sample_id');
----
true

# ---- PCA: id + 2 components = 3 columns, 150 rows ----

query I
SELECT count(*) FROM (DESCRIBE
  SELECT * FROM sklearn.pca((SELECT * FROM iris_feats), id => 'sample_id', n_components => 2));
----
3

query I
SELECT count(*) FROM sklearn.pca((SELECT * FROM iris_feats), id => 'sample_id', n_components => 2);
----
150

# ---- KMeans on well-separated blobs recovers the 3 clusters ----

query I
SELECT count(DISTINCT cluster) FROM sklearn.kmeans(
  (SELECT sample_id, feature_0, feature_1 FROM sklearn.make_blobs(n_samples => 150, centers => 3)),
  id => 'sample_id', n_clusters => 3);
----
3

# ---- IsolationForest flags some but not all rows as outliers ----

query I
SELECT (sum(is_outlier) > 0 AND sum(is_outlier) < count(*))
FROM sklearn.isolation_forest((SELECT * FROM iris_feats), id => 'sample_id', contamination => 0.1);
----
true

# ---- Agglomerative & GaussianMixture recover 3 clusters on well-separated blobs ----

query II
SELECT
  (SELECT count(DISTINCT cluster) FROM sklearn.agglomerative_clustering(
     (SELECT sample_id, feature_0, feature_1 FROM sklearn.make_blobs(n_samples => 150, centers => 3)),
     id => 'sample_id', n_clusters => 3)),
  (SELECT count(DISTINCT cluster) FROM sklearn.gaussian_mixture(
     (SELECT sample_id, feature_0, feature_1 FROM sklearn.make_blobs(n_samples => 150, centers => 3)),
     id => 'sample_id', n_components => 3));
----
3	3

# ---- LocalOutlierFactor flags some but not all rows ----

query I
SELECT (sum(is_outlier) > 0 AND sum(is_outlier) < count(*))
FROM sklearn.local_outlier_factor((SELECT * FROM iris_feats), id => 'sample_id');
----
true

# ---- t-SNE embeds every row into 2 components ----

query II
SELECT count(*), count(component_1) FILTER (WHERE component_2 IS NOT NULL)
FROM sklearn.tsne((SELECT * FROM iris_feats), id => 'sample_id', n_components => 2, perplexity => 30);
----
150	150

# ---- MaxAbsScaler keeps every value within [-1, 1] ----

query I
SELECT bool_and(abs(sepal_length_cm) <= 1.0 AND abs(petal_length_cm) <= 1.0)
FROM sklearn.maxabs_scaler((SELECT * FROM iris_feats), id => 'sample_id');
----
true

# ---- KBinsDiscretizer maps each feature to integer bins ----

query I
SELECT count(DISTINCT petal_length_cm)
FROM sklearn.kbins_discretizer((SELECT * FROM iris_feats), id => 'sample_id', n_bins => 4);
----
4

# ---- Normalizer scales each row to unit L2 norm ----

query I
SELECT bool_and(abs(sepal_length_cm*sepal_length_cm + sepal_width_cm*sepal_width_cm
                  + petal_length_cm*petal_length_cm + petal_width_cm*petal_width_cm - 1.0) < 1e-9)
FROM sklearn.normalizer((SELECT * FROM iris_feats), id => 'sample_id');
----
true

# ---- SimpleImputer fills NULLs with a column statistic (rows preserved) ----

query II
SELECT count(*), bool_and(sepal_length_cm IS NOT NULL)
FROM sklearn.simple_imputer(
  (SELECT sample_id, CASE WHEN sample_id = 0 THEN NULL ELSE sepal_length_cm END AS sepal_length_cm,
          sepal_width_cm, petal_length_cm, petal_width_cm FROM sklearn.iris()),
  id => 'sample_id', strategy => 'median');
----
150	true

# ---- TruncatedSVD reduces to component_1..k (k < n_features) ----

query I
SELECT count(*) FROM sklearn.truncated_svd((SELECT * FROM iris_feats), id => 'sample_id', n_components => 2)
WHERE component_1 IS NOT NULL AND component_2 IS NOT NULL;
----
150

# ---- DBSCAN labels well-separated blobs (>=1 cluster, noise allowed as -1) ----

query I
SELECT count(DISTINCT cluster) >= 1 AND min(cluster) >= -1 FROM sklearn.dbscan(
  (SELECT sample_id, feature_0, feature_1 FROM sklearn.make_blobs(n_samples => 150, centers => 3)),
  id => 'sample_id', eps => 1.5);
----
true

# ---- ordinal_encoder: one integer code column per string feature ----

# 150 rows preserved; the 3 species map to exactly 3 distinct codes {0,1,2}
query III
SELECT count(*), count(DISTINCT target_name), min(target_name) >= 0 AND max(target_name) = 2
FROM sklearn.ordinal_encoder((SELECT sample_id, target_name FROM sklearn.iris()), id => 'sample_id');
----
150	3	true

# codes are assigned alphabetically: setosa < versicolor < virginica -> 0,1,2
query I
SELECT bool_and(code = expected) FROM (
  SELECT e.target_name AS code,
         CASE i.target_name WHEN 'setosa' THEN 0 WHEN 'versicolor' THEN 1 ELSE 2 END AS expected
  FROM sklearn.ordinal_encoder((SELECT sample_id, target_name FROM sklearn.iris()), id => 'sample_id') e
  JOIN sklearn.iris() i USING (sample_id));
----
true

# ---- one_hot_encoder: long format, one active cell per row ----

# exactly one active category per input row (150), all value 1.0
query III
SELECT count(*), count(DISTINCT category), bool_and(value = 1.0)
FROM sklearn.one_hot_encoder((SELECT sample_id, target_name FROM sklearn.iris()), id => 'sample_id');
----
150	3	true

# pivots back to a wide one-hot whose row sums are 1 (inactive cells are NULL -> 0)
query I
SELECT bool_and(coalesce(setosa, 0) + coalesce(versicolor, 0) + coalesce(virginica, 0) = 1) FROM (
  PIVOT sklearn.one_hot_encoder((SELECT sample_id, target_name FROM sklearn.iris()), id => 'sample_id')
  ON category USING sum(value) GROUP BY sample_id);
----
true

statement ok
DETACH sklearn;
