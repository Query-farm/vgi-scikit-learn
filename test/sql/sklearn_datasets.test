# name: test/sql/sklearn_datasets.test
# description: Catalog discovery and the iris dataset table function
# group: [vgi_sklearn]

require-env VGI_SKLEARN_WORKER

require vgi

require httpfs

# ============================================================================
# Catalog discovery
# ============================================================================

query I
SELECT catalog FROM vgi_catalogs('${VGI_SKLEARN_WORKER}');
----
sklearn

# ============================================================================
# ATTACH and schema discovery
# ============================================================================

statement ok
ATTACH 'sklearn' AS sklearn (TYPE vgi, LOCATION '${VGI_SKLEARN_WORKER}');

query II rowsort
SELECT catalog_name, schema_name FROM information_schema.schemata WHERE catalog_name = 'sklearn';
----
sklearn	datasets
sklearn	estimators
sklearn	metrics
sklearn	models
sklearn	preprocessing

# ============================================================================
# iris()
# ============================================================================

# 150 samples
query I
SELECT count(*) FROM sklearn.datasets.iris();
----
150

# 7 columns: sample_id + 4 features + target + target_name
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM sklearn.datasets.iris());
----
7

# Three balanced species, 50 each
query II rowsort
SELECT target_name, count(*) FROM sklearn.datasets.iris() GROUP BY target_name;
----
setosa	50
versicolor	50
virginica	50

# Projection + aggregation pushes through cleanly
query I
SELECT round(avg(petal_length_cm), 3) FROM sklearn.datasets.iris() WHERE target_name = 'setosa';
----
1.462

# digits: 1797 handwritten-digit rows across 10 classes
query II
SELECT count(*), count(DISTINCT target) FROM sklearn.datasets.digits();
----
1797	10

statement ok
DETACH sklearn;
