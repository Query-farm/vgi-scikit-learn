# name: test/sql/sklearn_splitters.test
# description: CV splitter table functions (kfold / stratified / group / timeseries)
# group: [vgi_sklearn]

require-env VGI_SKLEARN_WORKER

require vgi

require httpfs

statement ok
ATTACH 'sklearn' AS sklearn (TYPE vgi, LOCATION '${VGI_SKLEARN_WORKER}');

statement ok
CREATE TEMP VIEW iris AS SELECT * FROM sklearn.datasets.iris();

# ---- kfold: every row gets exactly one fold in [0, n_splits) ----

query IIII
SELECT count(*), count(DISTINCT fold), min(fold), max(fold)
FROM sklearn.models.kfold((SELECT sample_id FROM iris), id := 'sample_id', n_splits := 5);
----
150	5	0	4

# the 5 folds are equal-sized (one distinct fold size)
query I
SELECT count(DISTINCT cnt) FROM (
  SELECT fold, count(*) AS cnt
  FROM sklearn.models.kfold((SELECT sample_id FROM iris), id := 'sample_id', n_splits := 5) GROUP BY fold);
----
1

# ---- stratified_kfold: each fold keeps every class's proportion (10 per class per fold) ----

query I
SELECT bool_and(n = 10) FROM (
  SELECT k.fold, i.target, count(*) AS n
  FROM sklearn.models.stratified_kfold((SELECT sample_id, target FROM iris), id := 'sample_id', label := 'target', n_splits := 5) k
  JOIN iris i USING (sample_id)
  GROUP BY k.fold, i.target);
----
true

# ---- group_kfold: a group never spans folds (group = species -> each in one fold) ----

query I
SELECT bool_and(n_folds = 1) FROM (
  SELECT i.target, count(DISTINCT k.fold) AS n_folds
  FROM sklearn.models.group_kfold((SELECT sample_id, target AS grp FROM iris), id := 'sample_id', group_col := 'grp', n_splits := 3) k
  JOIN iris i USING (sample_id)
  GROUP BY i.target);
----
true

# ---- timeseries_split: expanding windows; every test row follows its train rows ----

query III
SELECT count(DISTINCT split),
       count(*) FILTER (WHERE role = 'train') > 0,
       count(*) FILTER (WHERE role = 'test') > 0
FROM sklearn.models.timeseries_split((SELECT sample_id FROM iris ORDER BY sample_id), id := 'sample_id', n_splits := 5);
----
5	true	true

query I
SELECT bool_and(max_train < min_test) FROM (
  SELECT split,
         max(sample_id) FILTER (WHERE role = 'train') AS max_train,
         min(sample_id) FILTER (WHERE role = 'test') AS min_test
  FROM sklearn.models.timeseries_split((SELECT sample_id FROM iris ORDER BY sample_id), id := 'sample_id', n_splits := 5)
  GROUP BY split);
----
true

# ---- omitting id is a clear error ----

statement error
SELECT * FROM sklearn.models.kfold((SELECT sample_id FROM iris));
----
requires 'id'

statement ok
DETACH sklearn;
