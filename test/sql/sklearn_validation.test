# name: test/sql/sklearn_validation.test
# description: Argument/column validation gives clear errors (not opaque ones)
# group: [vgi_sklearn]

require-env VGI_SKLEARN_WORKER

require vgi

require httpfs

statement ok
ATTACH 'sklearn' AS sklearn (TYPE vgi, LOCATION '${VGI_SKLEARN_WORKER}');

statement ok
CREATE TEMP VIEW tr AS
  SELECT sample_id, sepal_length_cm AS f1, sepal_width_cm AS f2,
         petal_length_cm AS f3, petal_width_cm AS f4, target
  FROM sklearn.iris();

# := and => are equivalent named-argument syntaxes in DuckDB
query I
SELECT count(DISTINCT cluster) FROM sklearn.kmeans((SELECT sample_id, f1, f2 FROM tr), id := 'sample_id', n_clusters := 3);
----
3

# ---- non-numeric feature column -> clear error (not "could not convert string to float") ----
statement error
SELECT * FROM sklearn.pca((SELECT * FROM sklearn.iris()), id := 'sample_id', n_components := 2);
----
must be numeric

# ---- missing required args -> clear errors ----
# model_name is optional (fit always returns a model BLOB); target is required.
statement error
SELECT * FROM sklearn.fit((SELECT * FROM tr), model_name := 'm', estimator := 'logistic_regression');
----
requires 'target'

# fit without model_name succeeds and returns a non-empty model BLOB
query I
SELECT octet_length(model) > 0
FROM sklearn.fit((SELECT * FROM tr), estimator := 'logistic_regression', target := 'target', id := 'sample_id');
----
true

# ---- unknown hyperparameter -> lists valid params ----
statement error
SELECT * FROM sklearn.fit((SELECT * FROM tr), model_name := 'm', target := 'target', params := '{"nonsense": 5}');
----
unknown hyperparameter

# ---- train, then predict with a missing feature column -> clear error ----
statement ok
SELECT * FROM sklearn.fit((SELECT * FROM tr), model_name := 'valmodel',
                          estimator := 'logistic_regression', target := 'target', id := 'sample_id');

statement error
SELECT * FROM sklearn.predict((SELECT sample_id, f1, f2, f3 FROM tr), model_name := 'valmodel', id := 'sample_id');
----
requires feature column

# predict realigns by name: reordered columns still score every row
query I
SELECT count(*) FROM sklearn.predict((SELECT sample_id, f4, f3, f2, f1 FROM tr), model_name := 'valmodel', id := 'sample_id');
----
150

statement ok
SELECT * FROM sklearn.drop_model('valmodel');

statement ok
DETACH sklearn;
