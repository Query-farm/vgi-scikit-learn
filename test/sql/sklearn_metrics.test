# name: test/sql/sklearn_metrics.test
# description: Metric aggregate functions over (y_true, y_pred)
# group: [vgi_sklearn]

require-env VGI_SKLEARN_WORKER

require vgi

require httpfs

statement ok
ATTACH 'sklearn' AS sklearn (TYPE vgi, LOCATION '${VGI_SKLEARN_WORKER}');

# A tiny predictions table
statement ok
CREATE TEMP TABLE preds AS
SELECT * FROM (VALUES
  (1.0, 1.0),
  (2.0, 2.0),
  (3.0, 3.0),
  (4.0, 4.0)
) AS t(actual, predicted);

# Perfect predictions: R^2 = 1, MSE = 0, MAE = 0
query III
SELECT
  round(sklearn.r2_score(actual, predicted), 6),
  round(sklearn.mean_squared_error(actual, predicted), 6),
  round(sklearn.mean_absolute_error(actual, predicted), 6)
FROM preds;
----
1.0	0.0	0.0

# Classification: 3 of 4 correct -> accuracy 0.75
statement ok
CREATE TEMP TABLE cls AS
SELECT * FROM (VALUES (0,0),(1,1),(0,1),(1,1)) AS t(y, yhat);

query I
SELECT round(sklearn.accuracy_score(y, yhat), 4) FROM cls;
----
0.75

# added classification losses on the same table (y=[0,1,0,1], yhat=[0,1,1,1])
query III
SELECT round(sklearn.hamming_loss(y, yhat), 4),
       round(sklearn.zero_one_loss(y, yhat), 4),
       round(sklearn.jaccard_score(y, yhat), 4)
FROM cls;
----
0.25	0.25	0.5833

# added regression metrics (non-negative values for log error)
query II
SELECT round(sklearn.mean_squared_log_error(actual, predicted), 6),
       round(sklearn.mean_pinball_loss(actual, predicted), 6)
FROM (VALUES (3.0, 2.5), (1.0, 1.2), (5.0, 4.5)) AS t(actual, predicted);
----
0.011495	0.2

# score-based metrics: y_pred is a probability/score, not a hard label
statement ok
CREATE TEMP TABLE scored AS
SELECT * FROM (VALUES
  (0, 0.2), (0, 0.3), (0, 0.4), (1, 0.6), (1, 0.7), (1, 0.8), (0, 0.55), (1, 0.9)
) AS t(y, s);

query IIII
SELECT round(sklearn.roc_auc_score(y, s), 4),
       round(sklearn.average_precision_score(y, s), 4),
       round(sklearn.brier_score_loss(y, s), 4),
       round(sklearn.log_loss(y, s), 4)
FROM scored;
----
1.0	1.0	0.1116	0.3856

# Grouped metrics: one perfect group, one inverted group
statement ok
CREATE TEMP TABLE g AS
SELECT * FROM (VALUES
  ('a', 1.0, 1.0), ('a', 2.0, 2.0), ('a', 3.0, 3.0),
  ('b', 1.0, 3.0), ('b', 2.0, 2.0), ('b', 3.0, 1.0)
) AS t(grp, actual, predicted);

query II
SELECT grp, round(sklearn.r2_score(actual, predicted), 4) AS r2
FROM g GROUP BY grp ORDER BY grp;
----
a	1.0
b	-3.0

statement ok
DETACH sklearn;
